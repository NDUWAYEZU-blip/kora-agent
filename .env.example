# ── Kora Agent Configuration ─────────────────────────────────────────────────
# Copy this file to .env and fill in your actual paths.
# All paths use Windows backslash notation.

# Project paths
BACKEND_PATH=C:\Projects\kora-backend
FRONTEND_PATH=C:\Projects\kora-frontend

# Tool paths (update to match your installation)
VSCODE_PATH=C:\Users\YourUsername\AppData\Local\Programs\Microsoft VS Code\Code.exe
PGADMIN_PATH=C:\Program Files\pgAdmin 4\runtime\pgAdmin4.exe
GIT_BASH_PATH=C:\Program Files\Git\bin\bash.exe
DOCKER_DESKTOP_PATH=C:\Program Files\Docker\Docker\Docker Desktop.exe

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
REDIS_PORT=6379

# Redis
REDIS_IMAGE=redis:7
REDIS_CONTAINER_NAME=kora-redis

# Timeouts (seconds)
DOCKER_BOOT_TIMEOUT=120
DOCKER_POLL_INTERVAL=5
BACKEND_STARTUP_TIMEOUT=60
FRONTEND_STARTUP_TIMEOUT=90
PGADMIN_STARTUP_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
# LOG_DIR defaults to ./logs — override if needed
# LOG_DIR=C:\Logs\kora-agent
